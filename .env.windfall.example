# Windfall LLM Proxy Configuration
# Set these to route AI calls through Windfall instead of Anthropic directly.
# When WINDFALL_API_KEY is unset, the app falls back to direct Anthropic calls.

WINDFALL_API_KEY=wf_HMDs53MkkieoJ5B23orsnl6hX_RiRjaGtrI49-79enQ
WINDFALL_BASE_URL=https://windfall.ecofrontiers.xyz/v1

# Routing mode: 'greenest' (default), 'cheapest', or 'balanced'
WINDFALL_ROUTING_MODE=greenest

# Model: 'auto' (default, DeepSeek V3) or e.g. 'anthropic/claude-sonnet-4-6'
WINDFALL_MODEL=anthropic/claude-sonnet-4-6
